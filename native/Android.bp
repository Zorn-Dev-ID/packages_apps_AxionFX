package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

filegroup {
    name: "axionfx_engine_srcs",
    srcs: [
        "AxionFxEngine.cpp",
        "effects/Equalizer.cpp",
        "effects/BassBoost.cpp",
        "effects/StereoWidener.cpp",
        "effects/Limiter.cpp",
        "effects/Reverb.cpp",
        "effects/Compressor.cpp",
        "effects/TubeSimulator.cpp",
        "effects/AutoGainControl.cpp",
        "effects/Crossfeed.cpp",
        "effects/DiffSurround.cpp",
        "effects/Convolver.cpp",
        "effects/MultibandCompressor.cpp",
        "effects/Exciter.cpp",
        "effects/FirEqualizer.cpp",
        "effects/SteamSpatial.cpp",
        "dsp/Biquad.cpp",
        "dsp/EnvelopeFollower.cpp",
        "dsp/WavLoader.cpp",
    ],
    visibility: ["//packages/apps/AxionFx:__subpackages__"],
}

cc_library_shared {
    name: "libaxionfxaidl",

    defaults: [
        "aidlaudioeffectservice_defaults",
    ],

    srcs: [
        "AxionFxEffect.cpp",
        ":axionfx_engine_srcs",
        ":effectCommonFile",
    ],

    static_libs: [
        "libpffft",
        "libsteamaudio",
    ],

    local_include_dirs: ["."],

    relative_install_path: "soundfx",

    visibility: [
        "//hardware/interfaces/audio/aidl/default:__subpackages__",
    ],

    vendor: true,
}
